# Identity + secrets injected into the container at creation time via
# `docker --env-file`. Copy this file to devcontainer.env (gitignored),
# fill it in, and rebuild the container. No host shell exports involved —
# this file is the single source, so rebuilds are deterministic regardless
# of how VS Code was launched.
#
# Format: KEY=value, no quotes, no `export`.

# The agent's git identity — its own GitHub account (README §1)
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GIT_COMMITTER_NAME=
GIT_COMMITTER_EMAIL=

# Personal access token for that account — gh and git-over-HTTPS use it
GH_TOKEN=

# Long-lived Claude subscription token from `claude setup-token` on the host
# (prefer API billing? leave this empty and set ANTHROPIC_API_KEY instead)
CLAUDE_CODE_OAUTH_TOKEN=
