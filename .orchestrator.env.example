# Identity + secrets for LOCAL mode (ORCH_ENV=local — running the loop
# directly on an isolated machine, no devcontainer). Copy this file to
# .orchestrator.env in the PROJECT repo root (it is git-excluded
# automatically) and fill it in. Container mode ignores it and uses
# .devcontainer/devcontainer.env instead.
#
# Loaded by orchestrate and by every worker when the environment carries no
# auth token. Format: KEY=value, no quotes, no `export`.

# The agent's git identity — its own GitHub account (README §1)
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GIT_COMMITTER_NAME=
GIT_COMMITTER_EMAIL=

# Personal access token for that account — gh and git-over-HTTPS use it
GH_TOKEN=

# Long-lived Claude subscription token from `claude setup-token`
# (prefer API billing? leave this empty and set ANTHROPIC_API_KEY instead)
CLAUDE_CODE_OAUTH_TOKEN=
