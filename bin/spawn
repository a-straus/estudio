#!/usr/bin/env bash
# spawn [--model <model>] [--effort <level>] [--include <path>]... \
#       <branch> "<task>" [base-ref]
# Launch a headless worker agent on its own branch + worktree.
#
# Model routing: workers default to $WORKER_MODEL at $WORKER_EFFORT (or the
# CLI defaults if unset); pass --model to put a specific task on a stronger
# model (trunk fixes, reviews, gnarly tasks) and --effort to set its
# thinking depth (low|medium|high|xhigh|max).
#
# The worker runs `claude -p` non-interactively: it receives the task brief as
# its prompt (plus the quality bar and escalation rules from GOAL.md §12/§13),
# works, commits, and exits. A wrapper records claude's exit code in
# <worktree>/.worker-done — that marker, not tmux state, is the completion
# signal. The full event stream is logged to <repo>/logs/<branch>.<ts>.jsonl.
#
# Re-running spawn for an existing branch (after a crash, container restart,
# failed check, or resolved blocker) relaunches a worker in the same worktree
# to resume from the prior commits.
#
# Worktrees live under $WORKTREE_ROOT (default ~/worktrees), outside /workspace,
# and get a sparse checkout that excludes the orchestrator's context: CLAUDE.md,
# GOAL.md, the state files, and design/. The brief is the worker's whole
# instruction set; --include grants a context file back into the tree (the
# design files a brief names, or GOAL.md + design for reviewers). All source
# code is always present.
#
# Exit codes: 0 spawned · 1 usage/state error · 2 capacity full ·
#             3 architecture in flight (CRITIQUE.md on base, or uncommitted
#               ARCHITECTURE.md / design/ changes) — reconcile & commit first
set -euo pipefail
. "$(dirname "$0")/_lib.sh"

usage='usage: spawn [--model <model>] [--effort <level>] [--include <path>]... <branch> "<task>" [base-ref]'
model="${WORKER_MODEL:-}"
effort="${WORKER_EFFORT:-}"
includes=()
while [[ "${1:-}" == --* ]]; do
    case "$1" in
        --model)   model="${2:?$usage}";  shift 2 ;;
        --effort)  effort="${2:?$usage}"; shift 2 ;;
        --include) includes+=("${2:?$usage}"); shift 2 ;;
        *) die "$usage (unknown option: $1)" ;;
    esac
done

branch="${1:?$usage}"
task="${2:?$usage}"
base="${3:-HEAD}"

MAX_WORKERS="${MAX_WORKERS:-3}"
MAX_WORKER_TURNS="${MAX_WORKER_TURNS:-150}"
WORKER_TIMEOUT_SECS="${WORKER_TIMEOUT_SECS:-7200}"

root="$(repo_root)"
[[ -n "$root" ]] || die "not inside a git repository"
valid_branch "$branch" || die "branch name must be kebab-case ([a-z0-9._-], no slashes): $branch"
[[ "$branch" != "$(base_branch "$root")" ]] || die "refusing to spawn on the base branch"

wt="$(worktree_path "$root" "$branch")"

# ── State checks ──────────────────────────────────────────────────────────────

if worker_window_live "$branch"; then
    die "a worker for '$branch' is already running (tmux window '$branch')"
fi

if [[ -f "$wt/.worker-done" ]]; then
    echo "ERROR: '$branch' already has a finished worker awaiting action." >&2
    echo "Run 'integrate $branch' or 'abandon $branch' first." >&2
    exit 1
fi

if (( $(running_workers "$root") >= MAX_WORKERS )); then
    echo "ERROR: worker capacity full ($MAX_WORKERS running). Integrate or wait first." >&2
    exit 2
fi

# ── Architecture-in-flight guard ──────────────────────────────────────────────
# Workers fork from a commit and never see what lands on base afterwards. If
# the architecture is still being settled when a worker forks, it builds
# against a schema that is about to change (the bootstrap/stale-ARCHITECTURE
# incident). Two tripwires:
#   1. CRITIQUE.md on the base branch = the critique has been integrated but
#      not yet reconciled — ARCHITECTURE.md/design are about to move.
#   2. Uncommitted ARCHITECTURE.md or design/ changes = the contract on disk
#      is ahead of HEAD; a worker forked now would be blind to it.
main_base="$(base_branch "$root")"
if git -C "$root" cat-file -e "$main_base:CRITIQUE.md" 2>/dev/null; then
    echo "ERROR: CRITIQUE.md exists on '$main_base' — the architecture critique has" >&2
    echo "not been reconciled yet. Finish the reconcile pass (adopt/reject findings," >&2
    echo "finalize ARCHITECTURE.md, git rm CRITIQUE.md, commit) before spawning workers." >&2
    exit 3
fi
if [[ -n "$(git -C "$root" status --porcelain -- ARCHITECTURE.md design 2>/dev/null)" ]]; then
    echo "ERROR: ARCHITECTURE.md or design/ has uncommitted changes — workers fork" >&2
    echo "from a commit and would never see them. Commit the contract, then spawn." >&2
    exit 3
fi

# ── Create or reattach the worktree ──────────────────────────────────────────

mkdir -p "$WORKTREE_ROOT" "$root/logs"
ensure_excludes "$root"
git -C "$root" worktree prune

resume=""
if git -C "$root" show-ref --quiet "refs/heads/$branch"; then
    resume="yes"
    if [[ -d "$wt" && ! -e "$wt/.git" ]]; then
        rm -rf "$wt"    # leftover dir that is no longer a registered worktree
    fi
    if [[ ! -d "$wt" ]]; then
        git -C "$root" worktree add "$wt" "$branch"
    fi
else
    git -C "$root" worktree add -b "$branch" "$wt" "$base"
fi

# Context isolation: the worker's tree carries all of the source code but
# none of the orchestrator's context. CLAUDE.md (auto-loaded by `claude -p`
# from the cwd), GOAL.md, the state files, and design/ are sparse-excluded
# without git treating them as deletions (skip-worktree), so `git add -A`
# cannot touch them. --include grants a file back: the design files a brief
# names, or GOAL.md + design for reviewers. design/ is excluded per-file
# because gitignore-style patterns cannot re-include a file whose parent
# directory is excluded.
included() {    # was this path (or an ancestor of it) granted via --include?
    local f="$1" inc
    for inc in ${includes[@]+"${includes[@]}"}; do
        inc="${inc%/}"
        [[ "$f" == "$inc" || "$f" == "$inc"/* ]] && return 0
    done
    return 1
}
sparse=('/*' '!/CLAUDE.md')
for f in GOAL.md TASKS.md QUESTIONS.md DECISIONS.md FEEDBACK.md; do
    included "$f" || sparse+=("!/$f")
done
while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    included "$f" || sparse+=("!/$f")
done < <(git -C "$wt" ls-tree -r --name-only HEAD -- design 2>/dev/null)
git -C "$wt" sparse-checkout set --no-cone "${sparse[@]}" \
    || echo "WARNING: could not sparse-exclude orchestrator context from the worker worktree" >&2

# ── Build the worker prompt ───────────────────────────────────────────────────
# Pull the quality bar and escalation rules from GOAL.md. (Flag-based awk: a
# /start/,/end/ range would end on the heading line itself, yielding nothing.)

goal_file="$root/GOAL.md"
quality_bar=""
escalation=""
if [[ -f "$goal_file" ]]; then
    quality_bar=$(awk '/^### ★ 12 · Quality Bar/{f=1; next} /^### |^## |^---/{f=0} f' "$goal_file" \
        | sed '/^<!--/d; /^$/d' || true)
    escalation=$(awk '/^### ★ 13 · Escalation/{f=1; next} /^### |^## |^---/{f=0} f' "$goal_file" \
        | sed '/^<!--/d; /^$/d' || true)
fi

resume_note=""
if [[ -n "$resume" ]]; then
    resume_note="
## Resuming prior work

A previous worker already started this task on this branch. Before doing
anything else, review the existing state with \`git log --oneline -15\` and
\`git log -p -5\`. Keep what is good, fix what is not, and finish the task.
If a BLOCKED.md file exists, the blocker has been addressed in the brief
above: resolve it, delete BLOCKED.md, and complete the task.
"
fi

cat > "$wt/.worker-prompt.md" <<EOF
You are a focused, autonomous worker agent on branch '$branch' of this
repository. Complete the task below, prove it works, commit, and exit.

## Your task

$task
$resume_note
## Quality bar

${quality_bar:-Required hygiene: tests for new logic, clear error messages, no hardcoded secrets.}

## When to stop instead (escalation)

${escalation:-Stop if you would need to make an irreversible change outside your task scope, or if a key design decision is missing that would change the implementation significantly.}

If you hit one of these, do NOT guess: write a file called BLOCKED.md
describing what is blocking you, what you tried, and what decision or input
you need. Commit it and exit.

Special case — data-model changes: if completing this task would require a
schema or data-model change beyond what this brief explicitly allows, do NOT
make it. Write BLOCKED.md whose FIRST line is exactly \`type: model-change\`,
followed by the proposed change, why it is needed, and what it impacts.
Commit it and exit. The orchestrator serializes all model changes.

## Rules

- Do this task and nothing else. Do not expand scope.
- Don't add features, refactor, or introduce abstractions beyond what the
  task requires. A bug fix doesn't need surrounding cleanup and a one-shot
  operation usually doesn't need a helper. Don't design for hypothetical
  future requirements: do the simplest thing that works well. Avoid
  premature abstraction and half-finished implementations. Don't add error
  handling, fallbacks, or validation for scenarios that cannot happen.
  Trust internal code and framework guarantees. Only validate at system
  boundaries (user input, external APIs). Don't use feature flags or
  backwards-compatibility shims when you can just change the code.
- When you have enough information to act, act — the brief is the spec; do
  not re-survey the repo to re-derive what it already tells you.
- Prove your work runs before declaring it done: run \`bash check.sh\` if the
  repo has one, or the relevant tests / the app itself. A clean compile is
  not proof. Report outcomes faithfully in your final summary and commit
  messages: only claim what a command output in this session backs up; if
  tests fail or a step was skipped, say so explicitly.
- Commit ALL changes with clear, descriptive messages before exiting.
- Never push, never open pull requests, never switch branches, never leave
  this worktree, never spawn other agents.
- If ARCHITECTURE.md exists in this repo, follow its entities and
  conventions exactly.
- The design contract for anything user-facing lives in the design/
  directory. If your task touches UI, your brief names the design/ files
  that apply, and those are the only design files present in this worktree:
  read them. Where the named
  files are silent, do not stop — extrapolate from the identity,
  principles, and token-usage rules. Once a token stylesheet and shared
  components exist in the code, compose those: reuse existing components
  before creating new ones, take final strings from the microcopy where
  defined, and never hardcode a raw visual value where a token exists. If
  you introduce a genuinely new shared component or token, say so in your
  final commit message so the orchestrator can fold it back into the
  contract.
- Never modify GOAL.md, TASKS.md, QUESTIONS.md, DECISIONS.md, FEEDBACK.md,
  ARCHITECTURE.md, or anything under design/ — integration is automatically
  refused for branches that touch them. GOAL.md is the human's spec;
  ARCHITECTURE.md changes go through the orchestrator's schema gate (see
  above), and the design contract is amended only by the orchestrator.
- Never modify check.sh, unless your brief explicitly says to create it and
  it does not exist yet — integration is automatically refused for branches
  that change an existing check.sh. If a build/test step must change, write
  BLOCKED.md instead.
EOF

# ── Write the runner and launch ───────────────────────────────────────────────

ts="$(date +%Y%m%d-%H%M%S)"
log="$root/logs/$branch.$ts.jsonl"

timeout_prefix=""
if command -v timeout >/dev/null 2>&1; then
    timeout_prefix="timeout $WORKER_TIMEOUT_SECS "
fi

cat > "$wt/.worker-run.sh" <<EOF
#!/usr/bin/env bash
set -uo pipefail
cd "$wt"
# Claude Code scrubs auth tokens from child-process environments, so workers
# load credentials themselves from the gitignored container env file.
if [ -z "\${CLAUDE_CODE_OAUTH_TOKEN:-}\${ANTHROPIC_API_KEY:-}" ] && [ -f "$root/.devcontainer/devcontainer.env" ]; then
    set -a; . "$root/.devcontainer/devcontainer.env"; set +a
fi
echo "[worker:$branch] started \$(date '+%F %T')"
echo "[worker:$branch] log: $log"
${timeout_prefix}claude -p --dangerously-skip-permissions \\
    --max-turns $MAX_WORKER_TURNS --verbose --output-format stream-json \\
    ${model:+--model "$model"} ${effort:+--effort "$effort"} \\
    < .worker-prompt.md 2>&1 | tee "$log"
ec=\${PIPESTATUS[0]}
echo "\$ec" > .worker-done
if [ -n "\${TMUX:-}" ]; then tmux rename-window "done-$branch" 2>/dev/null || true; fi
echo ""
echo "[worker:$branch] exited \$ec — run 'integrate $branch' (or 'abandon $branch')"
EOF
chmod +x "$wt/.worker-run.sh"

if command -v tmux >/dev/null 2>&1; then
    tmux has-session -t agents 2>/dev/null || tmux new-session -d -s agents -n shell
    # Clear any stale done-window from a previous run of this branch.
    kill_branch_windows "$branch"
    tmux new-window -t agents -n "$branch" -c "$wt" \
        "bash '$wt/.worker-run.sh'; exec \${SHELL:-bash}"
else
    nohup bash "$wt/.worker-run.sh" >/dev/null 2>&1 &
    echo "NOTE: tmux not found — worker running as background process $!"
fi

echo "Spawned worker on branch '$branch'${resume:+ (resuming existing branch)}${model:+ [model: $model]}${effort:+ [effort: $effort]}"
echo "  worktree: $wt"
echo "  log:      $log"
echo "  watch:    tmux attach -t agents    (window '$branch')"
